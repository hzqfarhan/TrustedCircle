# ─── Data Source ───
# Set to 'false' to use real AWS DynamoDB instead of MockDB
USE_MOCK_DB=false

# ─── AWS Credentials ───
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── DynamoDB Table Names (must match AWS console exactly) ───
DYNAMODB_PROFILES_TABLE=Users
DYNAMODB_CHILD_PROFILES_TABLE=ChildProfiles
DYNAMODB_PARENT_CHILD_LINKS_TABLE=UserChildLink
DYNAMODB_TRANSACTIONS_TABLE=Transactions
DYNAMODB_ALLOWANCE_RULES_TABLE=AllowanceRules
DYNAMODB_ALLOWANCE_RECOMMENDATIONS_TABLE=AllowanceRecommendations
DYNAMODB_EXTRA_ALLOWANCE_REQUESTS_TABLE=ExtraAllowanceRequests
DYNAMODB_GOALS_TABLE=Goals
DYNAMODB_BADGES_TABLE=Badges
DYNAMODB_CHILD_BADGES_TABLE=ChildBadges
DYNAMODB_ALERTS_TABLE=Alerts
DYNAMODB_AUDIT_LOGS_TABLE=AuditLogs
DYNAMODB_CHILD_KYC_DOCUMENTS_TABLE=KYCDocuments
DYNAMODB_SHARED_FUNDS_TABLE=SharedFunds
DYNAMODB_APPROVALS_TABLE=Approvals

# ─── API Gateway (Lambda) ───
API_GATEWAY_URL=https://hjqu25msbk.execute-api.ap-southeast-1.amazonaws.com/v1

# ─── Cognito ───
COGNITO_USER_POOL_ID=
